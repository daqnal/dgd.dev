    "svelte": "^5.49.2",
    "svelte-adapter-bun": "^1.0.1",
    "svelte-check": "^4.3.6",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "wrangler": "^4.63.0"
  },
  "dependencies": {
    "@lucide/svelte": "^0.564.0",
    "@sveltejs/adapter-vercel": "^6.3.1",
