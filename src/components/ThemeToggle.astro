<div id="theme-toggle-container-container">
  <div id="theme-toggle-container">
    <input type="checkbox" id="theme-toggle" />
    <label for="theme-toggle" id="light-label" class="invisible">
      <svg
        xmlns="http://www.w3.org/2000/svg"
        width="24"
        height="24"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        class="lucide lucide-sun-icon lucide-sun"
        ><circle cx="12" cy="12" r="4"></circle><path d="M12 2v2"></path><path
          d="M12 20v2"></path><path d="m4.93 4.93 1.41 1.41"></path><path
          d="m17.66 17.66 1.41 1.41"></path><path d="M2 12h2"></path><path
          d="M20 12h2"></path><path d="m6.34 17.66-1.41 1.41"></path><path
          d="m19.07 4.93-1.41 1.41"></path></svg
      >
    </label>
    <label for="theme-toggle" id="dark-label" class="invisible">
      <svg
        xmlns="http://www.w3.org/2000/svg"
        width="24"
        height="24"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        class="lucide lucide-moon-icon lucide-moon"
        ><path
          d="M20.985 12.486a9 9 0 1 1-9.473-9.472c.405-.022.617.46.402.803a6 6 0 0 0 8.268 8.268c.344-.215.825-.004.803.401"
        ></path></svg
      >
    </label>
    <script is:inline>
      (function () {
        const savedTheme = localStorage.getItem("theme");
        const systemPrefersDark = window.matchMedia(
          "(prefers-color-scheme: dark)",
        ).matches;
        const lightLabel = document.getElementById("light-label");
        const darkLabel = document.getElementById("dark-label");
        const isDark = savedTheme ? savedTheme === "dark" : systemPrefersDark;
        if (isDark) {
          lightLabel?.classList.remove("invisible");
        } else {
          darkLabel?.classList.remove("invisible");
        }
      })();
    </script>
  </div>
</div>

<script>
  const toggle = document.getElementById("theme-toggle") as HTMLInputElement;
  const lightLabel = document.getElementById("light-label");
  const darkLabel = document.getElementById("dark-label");

  const updateLabelVisibility = (isDark: boolean) => {
    if (isDark) {
      lightLabel?.classList.remove("invisible");
      darkLabel?.classList.add("invisible");
    } else {
      darkLabel?.classList.remove("invisible");
      lightLabel?.classList.add("invisible");
    }
  };

  if (toggle) {
    const currTheme = document.documentElement.getAttribute("data-theme");
    toggle.checked = currTheme === "dark";

    updateLabelVisibility(toggle.checked);

    toggle.addEventListener("change", () => {
      const newTheme = toggle.checked ? "dark" : "light";

      updateLabelVisibility(toggle.checked);

      document.documentElement.setAttribute("data-theme", newTheme);
      localStorage.setItem("theme", newTheme);

      window.dispatchEvent(
        new CustomEvent("theme-changed", { detail: newTheme }),
      );
    });
  }
</script>

<style>
  #theme-toggle-container-container {
    position: relative;
    top: 2px;
    display: inline-flex;
    align-items: center;
    width: 1.3em;
  }

  #theme-toggle-container {
    width: 1.3em;
    height: 1.3em;
    display: flex;
    place-content: center;
    align-items: center;
    background-color: var(--color-base-300);
    border-radius: 100%;
  }

  #theme-toggle-container label {
    width: 16px;
    height: 16px;
  }

  #theme-toggle-container label svg {
    position: absolute;
    width: 16px;
    height: 16px;
    cursor: pointer;
    user-select: none;
  }

  #theme-toggle-container label svg {
    transition: transform 0.2s ease-in-out;
  }

  #theme-toggle-container label svg:hover {
    transform: scale(1.1) rotate(45deg);
  }

  .invisible {
    display: none;
  }
</style>
